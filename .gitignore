/data/

# changelogs are tracked under CNS (gap #2 fix) — `.cursorrules` mandates a per-day entry per code change.

# Internal notes (not pushed)
/internal/

# Release requirements / design drafts (not pushed)
/releasereq/

# Generated by scripts/deploy.sh from app.yaml.template +
# scripts/deploy.config.sh. Edit the template and the config —
# never the rendered output.
/app.yaml

# Cookie jars / curl session dumps (may contain live session + CSRF tokens)
cookies*.txt
*.cookiejar

/logs/*
# Log files anywhere in the tree must never be committed
*.log
**/logs/

# MLflow local artifacts
mlflow.db
mlruns/
mlartifacts/
# src/.coding_rules.md is tracked under CNS (M1.P2 — closes gap #1). Referenced by 4+ canonical docs.
/src/.databricks/sync-snapshots

# Data folder
/data/

# changelogs are tracked under CNS (gap #2 fix) — `.cursorrules` mandates a per-day entry per code change.
# Negate the `*.log` blanket rule above so changelogs/<YYYY-MM-DD>.log keeps tracking.
#!changelogs/*.log

# Internal notes (not pushed)
/internal/

# Release requirements / design drafts (not pushed)
/releasereq/

# Generated by scripts/deploy.sh from *.template +
# scripts/deploy.config.sh. Edit the template and the config —
# never the rendered outputs.
/app.yaml
/src/mcp-server/app.yaml

# Cookie jars / curl session dumps (may contain live session + CSRF tokens)
cookies*.txt
*.cookiejar
tests/e2e/_e2e_server.log

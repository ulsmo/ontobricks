# OntoBricks Environment Configuration
# Copy this file to .env and fill in your values
#
# NOTE: For Databricks Apps deployment, most of these are set automatically
# by the platform. This file is primarily for LOCAL development.

# ============================================================================
# Databricks Connection (Required for Local Development)
# ============================================================================
# Your Databricks workspace URL (e.g., https://your-workspace.cloud.databricks.com)
DATABRICKS_HOST=

# Personal Access Token for authentication
# Generate at: Databricks Workspace > User Settings > Developer > Access Tokens
DATABRICKS_TOKEN=

# SQL Warehouse ID for query execution
# Find at: Databricks Workspace > SQL > SQL Warehouses > (select warehouse) > Connection details
DATABRICKS_SQL_WAREHOUSE_ID=

# ============================================================================
# MLflow Tracing (Optional)
# ============================================================================
# Send agent traces to your Databricks workspace instead of local mlflow.db.
# Requires DATABRICKS_HOST and DATABRICKS_TOKEN above.
MLFLOW_TRACKING_URI=databricks

# MLflow experiment name (default: ontobricks-agents)
# ONTOBRICKS_MLFLOW_EXPERIMENT=ontobricks-agents

# ============================================================================
# Application Settings (Optional)
# ============================================================================
# Secret key for session encryption (generate a secure random string)
# In production, use a strong random key
SECRET_KEY=your-secret-key-change-in-production

# Application port (default: 8000)
# Note: In Databricks Apps, this is set automatically via DATABRICKS_APP_PORT
# DATABRICKS_APP_PORT=8000

# ============================================================================
# Volume Path for Mapping Storage (Optional)
# ============================================================================
# Unity Catalog volume path for storing R2RML mappings
# Format: /Volumes/<catalog>/<schema>/<volume>
# VOLUME_PATH=/Volumes/main/ontobricks/mappings

# ============================================================================
# Registry Backend — Lakebase (Postgres)
# ============================================================================
REGISTRY_BACKEND=lakebase

# As of v0.4.0 the domain registry (domains, versions, permissions,
# schedules, global config) lives in Databricks Lakebase. The Unity
# Catalog Volume above is reserved for binary artifacts (documents/
# uploads — domain-scoped attachments imported by the ontology designer)
# only.
#
# Operators on a pre-v0.4.0 deployment with config still on the Volume
# must run ``scripts/migrate-registry-to-lakebase.sh`` once before
# upgrading.
#
# Set these four coordinates to identify the target Lakebase resource:
#
#   LAKEBASE_PROJECT          — Lakebase Autoscaling project name
#                             (e.g. ``ontobricks``)
#   LAKEBASE_BRANCH         — branch within that project
#                             (default: main; other branches for dev/staging)
#   LAKEBASE_DATABASE       — Postgres database to connect to
#                             (e.g. ``ontobricks_registry``)
#   LAKEBASE_SCHEMA         — Postgres schema where registry tables live
#                             (e.g. ``ontobricks_registry``)
#
# ``LakebaseAuth`` resolves the endpoint hostname automatically from
# LAKEBASE_PROJECT + LAKEBASE_BRANCH via the Postgres API, so you
# do NOT need to copy-paste the raw PGHOST URL for local development.
#
# In production (Databricks Apps with a ``database`` resource bound),
# the platform auto-injects PGHOST, PGPORT, PGDATABASE, PGUSER — those
# take precedence over the LAKEBASE_* vars and require no extra config.
# PGUSER is still required for local dev (your Databricks email):
#
# LAKEBASE_PROJECT=ontobricks
# LAKEBASE_BRANCH=main
# LAKEBASE_DATABASE=ontobricks_registry
# LAKEBASE_SCHEMA=ontobricks_registry
# PGUSER=you@example.com
#
# The Postgres password is a short-lived JWT minted at runtime by
# ``LakebaseAuth`` — never hardcode a password here.

# ============================================================================
# Unity Catalog Volume — binary artefacts (domain document uploads)
# ============================================================================
# The domain registry itself lives in Lakebase (above). The Volume is only
# used for binary attachments imported by the ontology designer.
#
# Full path resolved as: /Volumes/<REGISTRY_CATALOG>/<REGISTRY_SCHEMA>/<REGISTRY_VOLUME>
#
# In Databricks Apps the volume resource is auto-bound; for local dev set
# all three vars to point at your UC volume.
REGISTRY_CATALOG=
REGISTRY_SCHEMA=
REGISTRY_VOLUME=
